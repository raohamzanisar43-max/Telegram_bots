# ─────────────────────────────────────────────
#  Profitability Intelligence — Environment File
#  Copy to .env and fill in all REPLACE_WITH_... values
#  NEVER commit .env to git
# ─────────────────────────────────────────────

# ── Telegram Bot Tokens (create via @BotFather) ──
SIGNALS_BOT_TOKEN=REPLACE_WITH_SIGNALS_BOT_TOKEN
COPY_BOT_TOKEN=REPLACE_WITH_COPY_BOT_TOKEN
FUNDED_BOT_TOKEN=REPLACE_WITH_FUNDED_BOT_TOKEN

# ── VIP Channel (negative number, e.g. -1001234567890) ──
SIGNALS_VIP_CHANNEL_ID=REPLACE_WITH_CHANNEL_ID

# ── MetaAPI (from app.metaapi.cloud dashboard) ──
META_API_TOKEN=REPLACE_WITH_META_API_TOKEN
MT4_ACCOUNT_ID=REPLACE_WITH_MT4_ACCOUNT_ID

# ── PostgreSQL ──
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=profitability
POSTGRES_USER=pi_user
POSTGRES_PASSWORD=REPLACE_WITH_DB_PASSWORD

# ── Redis ──
REDIS_HOST=redis
REDIS_PORT=6379

# ── Admin API ──
ADMIN_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET

# ── General ──
LOG_LEVEL=INFO
TZ=UTC
